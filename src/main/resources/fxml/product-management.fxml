<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<SplitPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.mes.controller.ProductManagementController"
           dividerPositions="0.25"
           prefWidth="1200"
           prefHeight="600">

    <VBox spacing="10" styleClass="category-panel">
        <Label text="物料产品分类" styleClass="category-label"/>
        <TreeView fx:id="categoryTree" VBox.vgrow="ALWAYS"/>
        <Button text="🔄 刷新" onAction="#refreshCategoryTree" styleClass="action-button, secondary-button"/>
    </VBox>

    <VBox spacing="15" styleClass="content-panel">
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label styleClass="content-header" text="物料产品管理"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="addButton" styleClass="action-button, add-button" text="➕ 新增" onAction="#showAddDialog"/>
            <Button fx:id="editButton" styleClass="action-button, edit-button" text="✏️ 修改" onAction="#handleBatchEdit"/>
            <Button fx:id="deleteButton" styleClass="action-button, delete-button" text="🗑️ 删除" onAction="#handleBatchDelete"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="search-bar">
            <Label text="物料编码:" styleClass="search-label"/>
            <TextField fx:id="codeSearchField" promptText="请输入物料编码" styleClass="input-field" prefWidth="120"/>
            <Label text="物料名称:" styleClass="search-label"/>
            <TextField fx:id="nameSearchField" promptText="请输入物料名称" styleClass="input-field" prefWidth="120"/>
            <Label text="是否启用:" styleClass="search-label"/>
            <ComboBox fx:id="enabledSearchCombo" styleClass="input-field" prefWidth="120"/>
            <Button styleClass="action-button, primary-button" text="🔍 查询" onAction="#handleSearch"/>
            <Button styleClass="action-button, secondary-button" text="🔄 重置" onAction="#handleReset"/>
        </HBox>

        <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="selectColumn" text="选择" prefWidth="50">
                </TableColumn>
                <TableColumn fx:id="codeColumn" text="物料编码" prefWidth="100">
                </TableColumn>
                <TableColumn fx:id="nameColumn" text="物料名称" prefWidth="120">
                </TableColumn>
                <TableColumn fx:id="categoryColumn" text="分类" prefWidth="120">
                </TableColumn>
                <TableColumn fx:id="unitColumn" text="单位" prefWidth="60">
                </TableColumn>
                <TableColumn fx:id="specColumn" text="规格" prefWidth="100">
                </TableColumn>
                <TableColumn fx:id="stockRangeColumn" text="库存预警范围" prefWidth="100">
                </TableColumn>
                <TableColumn fx:id="enabledColumn" text="是否启用" prefWidth="80">
                </TableColumn>
                <TableColumn fx:id="actionColumn" text="操作" prefWidth="120">
                </TableColumn>
            </columns>
        </TableView>
    </VBox>
</SplitPane>
