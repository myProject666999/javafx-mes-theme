<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mes.controller.WorkstationController"
      spacing="15">

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label styleClass="content-header" text="工作站管理"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="exportButton" styleClass="action-button, success-button" text="📤 导出" onAction="#handleExport"/>
        <Button fx:id="addButton" styleClass="action-button, add-button" text="➕ 新增" onAction="#showAddDialog"/>
        <Button fx:id="editButton" styleClass="action-button, edit-button" text="✏️ 修改" onAction="#handleBatchEdit"/>
        <Button fx:id="deleteButton" styleClass="action-button, delete-button" text="🗑️ 删除" onAction="#handleBatchDelete"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="search-bar">
        <Label text="工作站名称:" styleClass="search-label"/>
        <TextField fx:id="nameSearchField" promptText="请输入工作站名称" styleClass="input-field" prefWidth="120"/>
        <Label text="所在车间:" styleClass="search-label"/>
        <ComboBox fx:id="workshopSearchCombo" styleClass="input-field" prefWidth="120">
            <items>
            </items>
        </ComboBox>
        <Label text="所属工序:" styleClass="search-label"/>
        <TextField fx:id="processSearchField" promptText="请输入工序名称" styleClass="input-field" prefWidth="120"/>
        <Label text="是否启用:" styleClass="search-label"/>
        <ComboBox fx:id="enabledSearchCombo" styleClass="input-field" prefWidth="120">
            <items>
            </items>
        </ComboBox>
        <Button styleClass="action-button, primary-button" text="🔍 查询" onAction="#handleSearch"/>
        <Button styleClass="action-button, secondary-button" text="🔄 重置" onAction="#handleReset"/>
    </HBox>

    <TableView fx:id="workstationTable" prefHeight="500">
        <columns>
            <TableColumn fx:id="codeColumn" text="工作站编码" prefWidth="100">
            </TableColumn>
            <TableColumn fx:id="nameColumn" text="工作站名称" prefWidth="120">
            </TableColumn>
            <TableColumn fx:id="workshopColumn" text="所在车间" prefWidth="120">
            </TableColumn>
            <TableColumn fx:id="processColumn" text="所属工序" prefWidth="100">
            </TableColumn>
            <TableColumn fx:id="equipmentCountColumn" text="设备数量" prefWidth="80">
            </TableColumn>
            <TableColumn fx:id="workerCountColumn" text="工人数量" prefWidth="80">
            </TableColumn>
            <TableColumn fx:id="descriptionColumn" text="描述" prefWidth="150">
            </TableColumn>
            <TableColumn fx:id="enabledColumn" text="是否启用" prefWidth="80">
            </TableColumn>
            <TableColumn fx:id="createTimeColumn" text="创建时间" prefWidth="150">
            </TableColumn>
            <TableColumn fx:id="actionColumn" text="操作" prefWidth="150">
            </TableColumn>
        </columns>
    </TableView>
</VBox>
