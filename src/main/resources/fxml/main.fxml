<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mes.controller.MainController"
            styleClass="root">

    <top>
        <HBox styleClass="title-bar" alignment="CENTER_LEFT">
            <padding>
                <Insets top="4" right="8" bottom="4" left="8"/>
            </padding>

            <Label fx:id="titleLabel" text="MES System"
                   styleClass="title-bar-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="0">
                <Button styleClass="window-button" text="─" onAction="#minimizeWindow"/>
                <Button fx:id="maximizeBtn" styleClass="window-button" text="□" onAction="#maximizeWindow"/>
                <Button styleClass="window-button, close-button" text="✕" onAction="#closeWindow"/>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar" prefWidth="200" spacing="2">
            <padding>
                <Insets top="10" bottom="10"/>
            </padding>

            <VBox fx:id="sidebarMenu" spacing="2">
                <Button styleClass="sidebar-button, active" text="🏠  控制台" onAction="#showDashboard"/>
                
                <Label fx:id="systemMenuLabel" text="系统管理" styleClass="menu-label"/>
                <Button fx:id="userMenuBtn" styleClass="sidebar-button" text="👥  用户管理" onAction="#showUserManagement"/>
                <Button fx:id="roleMenuBtn" styleClass="sidebar-button" text="🎭  角色管理" onAction="#showRoleManagement"/>
                <Button fx:id="permissionMenuBtn" styleClass="sidebar-button" text="🔑  权限管理" onAction="#showPermissionManagement"/>
                
                <Label fx:id="masterDataMenuLabel" text="主数据" styleClass="menu-label"/>
                <Button fx:id="uomMenuBtn" styleClass="sidebar-button" text="📏  计量单位" onAction="#showUnitOfMeasure"/>

                <Label fx:id="productMenuLabel" text="产品管理" styleClass="menu-label"/>
                <Button fx:id="productCategoryMenuBtn" styleClass="sidebar-button" text="📁  物料产品分类" onAction="#showProductCategory"/>
                <Button fx:id="productManagementMenuBtn" styleClass="sidebar-button" text="📦  物料产品管理" onAction="#showProductManagement"/>

                <Label fx:id="workshopMenuLabel" text="车间管理" styleClass="menu-label"/>
                <Button fx:id="workshopMenuBtn" styleClass="sidebar-button" text="🏭  车间设置" onAction="#showWorkshop"/>
                <Button fx:id="workstationMenuBtn" styleClass="sidebar-button" text="⚙️  工作站管理" onAction="#showWorkstation"/>

                <Label fx:id="personalMenuLabel" text="个人设置" styleClass="menu-label"/>
                <Button styleClass="sidebar-button" text="🔐  修改密码" onAction="#showChangePassword"/>
                <Button styleClass="sidebar-button" text="⚙️  界面设置" onAction="#showSettings"/>
                
                <Region VBox.vgrow="ALWAYS"/>
                <Separator styleClass="sidebar-separator"/>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <padding>
                        <Insets top="10" right="15" bottom="10" left="15"/>
                    </padding>
                    <Label fx:id="userInfoLabel" styleClass="user-info-label"/>
                </HBox>
                <Button styleClass="sidebar-button" text="🚪  退出登录" onAction="#logout"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane" styleClass="content-area">
            <padding>
                <Insets top="20" right="30" bottom="20" left="30"/>
            </padding>

            <VBox fx:id="dashboardView" spacing="20">
                <Label styleClass="content-header" text="控制台"/>

                <GridPane hgap="20" vgap="20">
                    <VBox styleClass="dashboard-card"
                          GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="👥 用户总数" styleClass="dashboard-card-label"/>
                        <Label fx:id="userCountLabel" styleClass="dashboard-card-value-user"/>
                    </VBox>

                    <VBox styleClass="dashboard-card"
                          GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="🎭 角色总数" styleClass="dashboard-card-label"/>
                        <Label fx:id="roleCountLabel" styleClass="dashboard-card-value-role"/>
                    </VBox>

                    <VBox styleClass="dashboard-card"
                          GridPane.columnIndex="2" GridPane.rowIndex="0">
                        <Label text="🔑 权限总数" styleClass="dashboard-card-label"/>
                        <Label fx:id="permissionCountLabel" styleClass="dashboard-card-value-perm"/>
                    </VBox>
                </GridPane>

                <VBox spacing="10">
                    <Label text="当前用户权限" styleClass="section-title"/>
                    <ListView fx:id="permissionListView" prefHeight="200"
                              styleClass="dashboard-list-view"/>
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
